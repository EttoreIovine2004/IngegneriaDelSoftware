<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd" version="3.1">

    <persistence-unit name="BibliotecaPU">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>Entity.Utente</class>
        <class>Entity.Studente</class>
        <class>Entity.Bibliotecario</class>
        <class>Entity.Prenotazione</class>
        <class>Entity.Notifica</class>
        <class>Entity.Postazione</class>
        <class>Entity.SalaStudio</class>
        <class>Entity.AreaTematica</class>

        <properties>

            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://127.0.0.1:3306/biblioteca_db"/>

            <property name="jakarta.persistence.jdbc.user" value="root"/>

            <property name="jakarta.persistence.jdbc.password" value="FORZANAPOLI"/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <property name="hibernate.show_sql" value="true"/>

            <property name="hibernate.format_sql" value="true"/>

        </properties>
    </persistence-unit>
</persistence>
